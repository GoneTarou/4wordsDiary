Table users {
  id bigint [pk]
  email varchar [unique, not null]
  password_digest varchar [not null]
  username varchar [not null]
  google_uid varchar [unique]
  guest boolean
  created_at datetime
  updated_at datetime
}

Table sessions {
  id bigint [pk]
  user_id bigint [not null, ref: > users.id]
  created_at datetime
  updated_at datetime
}

Table diaries {
  id bigint [pk]
  user_id bigint [not null, ref: > users.id]
  diary_date date
  body text
  published boolean
  created_at datetime
  updated_at datetime
}
