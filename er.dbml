Table users {
  id bigint [pk]
  email varchar [unique]
  username varchar
  password_digest varchar
  guest boolean
  guest_expires_at datetime
  created_at datetime
  updated_at datetime
}

Table sessions {
  id bigint [pk]
  user_id bigint [not null, ref: > users.id]
  ip_address varchar
  user_agent varchar
  created_at datetime
  updated_at datetime
}

Table oauth_accounts {
  id bigint [pk]
  user_id bigint [not null, ref: > users.id]
  provider varchar
  uid varchar
  created_at datetime
  updated_at datetime

  indexes {
    (provider, uid) [unique]
  }
}

Table diaries {
  id bigint [pk]
  user_id bigint [not null, ref: > users.id]
  diary_date date
  body text
  published boolean
  created_at datetime
  updated_at datetime
}